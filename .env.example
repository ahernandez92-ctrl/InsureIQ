# InsureIQ Environment Variables

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/insureiq?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Anthropic AI (for analysis narratives)
ANTHROPIC_API_KEY="sk-ant-..."

# Resend (for email delivery of reports)
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="reports@yourdomain.com"

# Supabase (for PDF report storage)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
