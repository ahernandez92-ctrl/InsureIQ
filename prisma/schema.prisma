generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String           @id @default(cuid())
  name               String?
  email              String?          @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  role               String           @default("AGENT")
  npn                String?
  state              String?
  agencyId           String?
  healthSherpaApiKey String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  accounts           Account[]
  analysisReports    AnalysisReport[]
  intakeTokens       IntakeToken[]
  sessions           Session[]
  agency             Agency?          @relation(fields: [agencyId], references: [id])
  carriers           Carrier[]        @relation("AgentCarriers")
  products           Product[]        @relation("AgentProducts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agency {
  id        String   @id @default(cuid())
  name      String
  tier      String   @default("STARTER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agents    User[]
}

model Carrier {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  agents    User[]    @relation("AgentCarriers")
}

model Product {
  id          String   @id @default(cuid())
  carrierId   String
  name        String
  code        String   @unique
  category    String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  prices      Price[]
  carrier     Carrier  @relation(fields: [carrierId], references: [id])
  agents      User[]   @relation("AgentProducts")
}

model Price {
  id        String   @id @default(cuid())
  productId String
  state     String
  ageFrom   Int
  ageTo     Int
  tier      String
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId, state])
}

model IntakeToken {
  id          String         @id @default(cuid())
  token       String         @unique @default(cuid())
  agentId     String
  clientName  String?
  clientEmail String?
  status      String         @default("PENDING")
  expiresAt   DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  profile     ClientProfile?
  agent       User           @relation(fields: [agentId], references: [id])
}

model ClientProfile {
  id                  String          @id @default(cuid())
  intakeTokenId       String          @unique
  firstName           String
  lastName            String
  email               String
  phone               String?
  dateOfBirth         DateTime?
  gender              String?
  maritalStatus       String?
  dependents          Int             @default(0)
  householdIncome     String?
  employmentStatus    String?
  employerName        String?
  hasExistingCoverage Boolean         @default(false)
  existingCarrier     String?
  monthlyBudget       Decimal?        @db.Decimal(10, 2)
  healthConditions    String?
  medications         String?
  tobaccoUser         Boolean?
  heightFeet          Int?
  heightInches        Int?
  weightLbs           Int?
  coverageGoals       String?
  interestedProducts  String?
  primaryConcern      String?
  consented           Boolean         @default(false)
  signature           String?
  submittedAt         DateTime        @default(now())
  analysis            AnalysisReport?
  intakeToken         IntakeToken     @relation(fields: [intakeTokenId], references: [id])
}

model AnalysisReport {
  id                 String        @id @default(cuid())
  clientProfileId    String        @unique
  agentId            String
  status             String        @default("DRAFT")
  eligibleProducts   Json?
  ineligibleProducts Json?
  scenarios          Json?
  bundles            Json?
  riskSummary        String?
  narrative          String?
  reportPdfUrl       String?
  errorMessage       String?
  generatedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  agent              User          @relation(fields: [agentId], references: [id])
  profile            ClientProfile @relation(fields: [clientProfileId], references: [id])

  @@index([agentId])
}
